PROJECT_NAME=MooveSaathi
APP_ENV=development
DEBUG=false
API_V1_STR=/api/v1
SECRET_KEY=replace-with-a-strong-32-plus-character-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=30
LOGIN_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
FORGOT_PASSWORD_RATE_LIMIT_MAX_REQUESTS=3
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=900
RESET_PASSWORD_RATE_LIMIT_MAX_REQUESTS=5
RESET_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=900
CHAT_MESSAGE_RATE_LIMIT_MAX_REQUESTS=20
CHAT_MESSAGE_RATE_LIMIT_WINDOW_SECONDS=60
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/moovesaathi
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5
AUTO_CREATE_TABLES=true
SQL_ECHO=false
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
